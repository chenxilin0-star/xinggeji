page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  background: linear-gradient(135deg, #6C5CE7 0%, #a29bfe 100%);
  min-height: 100vh;
  color: #333;
}

.container {
  padding: 20rpx;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(108, 92, 231, 0.15);
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.card-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.btn-primary {
  background: linear-gradient(135deg, #6C5CE7 0%, #a29bfe 100%);
  color: #fff;
  border: none;
  border-radius: 50rpx;
  padding: 24rpx 60rpx;
  font-size: 28rpx;
  box-shadow: 0 4rpx 15rpx rgba(108, 92, 231, 0.4);
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: #fff;
  color: #6C5CE7;
  border: 2rpx solid #6C5CE7;
  border-radius: 50rpx;
  padding: 24rpx 60rpx;
  font-size: 28rpx;
}

.btn-secondary::after {
  border: none;
}

.emoji {
  font-size: 48rpx;
  margin-right: 10rpx;
}
