page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'PingFang SC', 'Hiragino Sans GB', sans-serif;
  background: linear-gradient(135deg, #6C5CE7 0%, #a29bfe 100%);
  min-height: 100vh;
  color: #333;
  font-size: 28rpx;
}

.container {
  padding: 20rpx;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 6rpx 24rpx rgba(108, 92, 231, 0.15);
}

.card-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.card-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.btn-primary {
  background: linear-gradient(135deg, #6C5CE7 0%, #a29bfe 100%);
  color: #fff;
  border: none;
  border-radius: 50rpx;
  padding: 26rpx 64rpx;
  font-size: 30rpx;
  box-shadow: 0 6rpx 20rpx rgba(108, 92, 231, 0.4);
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: #fff;
  color: #6C5CE7;
  border: 2rpx solid #6C5CE7;
  border-radius: 50rpx;
  padding: 24rpx 60rpx;
  font-size: 28rpx;
}

.btn-secondary::after {
  border: none;
}

.emoji {
  font-size: 52rpx;
  margin-right: 12rpx;
}

/* 通用渐变背景 */
.gradient-bg {
  background: linear-gradient(135deg, #6C5CE7 0%, #a29bfe 100%);
}

/* 通用白色卡片 */
.white-card {
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 6rpx 24rpx rgba(108, 92, 231, 0.15);
}

/* 渐变按钮 */
.gradient-btn {
  background: linear-gradient(135deg, #6C5CE7 0%, #a29bfe 100%);
  color: #fff;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(108, 92, 231, 0.35);
}

/* 动画效果 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.fade-in {
  animation: fadeIn 0.4s ease forwards;
}

/* 弹性点击效果 */
.scale-tap:active {
  transform: scale(0.97);
  opacity: 0.9;
}

/* 渐变文字 */
.gradient-text {
  background: linear-gradient(135deg, #6C5CE7 0%, #a29bfe 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
