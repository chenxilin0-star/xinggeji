.container {
  padding: 30rpx;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

.header {
  text-align: center;
  padding: 50rpx 0 40rpx;
}

.logo {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.logo-emoji {
  font-size: 72rpx;
  margin-right: 16rpx;
}

.logo-text {
  font-size: 56rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 4rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.75);
  letter-spacing: 2rpx;
}

.test-list {
  margin-top: 24rpx;
}

.test-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  margin-bottom: 22rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 6rpx 24rpx rgba(108, 92, 231, 0.18);
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2,1);
  position: relative;
  overflow: hidden;
}

.test-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 8rpx;
  height: 100%;
  background: var(--card-color, #6C5CE7);
  opacity: 0;
  transition: opacity 0.25s ease;
}

.test-card:active {
  transform: scale(0.98);
}

.test-card:active::before {
  opacity: 1;
}

.test-emoji {
  font-size: 64rpx;
  margin-right: 28rpx;
}

.test-info {
  flex: 1;
}

.test-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.test-desc {
  font-size: 26rpx;
  color: #888;
  line-height: 1.5;
  margin-bottom: 14rpx;
}

.test-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.question-count {
  font-size: 22rpx;
  color: #6C5CE7;
  background: rgba(108, 92, 231, 0.1);
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.test-tag {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
  font-weight: 500;
}

.test-arrow {
  font-size: 52rpx;
  color: #d4d0e8;
  margin-left: 16rpx;
  font-weight: 300;
}

.footer-tip {
  text-align: center;
  padding: 50rpx 0 30rpx;
  color: rgba(255, 255, 255, 0.55);
  font-size: 24rpx;
}

.footer-tip text {
  display: inline-block;
  padding: 12rpx 28rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 30rpx;
}
