/* 首页样式 - 注意：app.wxss 中有全局 .container，这里必须覆盖 */

page {
  background: linear-gradient(135deg, #6C5CE7 0%, #a29bfe 100%);
  min-height: 100vh;
}

.container {
  padding: 30rpx !important;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

.header {
  text-align: center;
  padding: 50rpx 0 40rpx;
}

.logo {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.logo-emoji {
  font-size: 72rpx;
  margin-right: 16rpx;
}

.logo-text {
  font-size: 56rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 4rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.75);
  letter-spacing: 2rpx;
}

.test-list {
  margin-top: 24rpx;
}

.test-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  margin-bottom: 22rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 6rpx 24rpx rgba(108, 92, 231, 0.18);
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.test-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 8rpx;
  height: 100%;
  background: var(--card-color, #6C5CE7);
  opacity: 0;
  transition: opacity 0.25s ease;
}

.test-card:active {
  transform: scale(0.98);
}

.test-card:active::before {
  opacity: 1;
}

.test-emoji {
  font-size: 64rpx;
  margin-right: 28rpx;
  flex-shrink: 0;
}

.test-info {
  flex: 1;
  min-width: 0;
}

.test-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.test-desc {
  font-size: 26rpx;
  color: #888;
  line-height: 1.5;
  margin-bottom: 14rpx;
}

.test-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-wrap: wrap;
}

.question-count {
  font-size: 22rpx;
  color: #6C5CE7;
  background: rgba(108, 92, 231, 0.1);
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.test-tag {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
  font-weight: 500;
}

.test-arrow {
  font-size: 52rpx;
  color: #d4d0e8;
  margin-left: 16rpx;
  font-weight: 300;
  flex-shrink: 0;
}

.footer-tip {
  text-align: center;
  padding: 30rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.footer-tip text {
  color: rgba(255, 255, 255, 0.55);
  font-size: 24rpx;
}

.share-btn {
  display: inline-block;
  font-size: 24rpx !important;
  padding: 12rpx 32rpx !important;
  background: rgba(255, 255, 255, 0.15) !important;
  color: #fff !important;
  border: 2rpx solid rgba(255, 255, 255, 0.25) !important;
  border-radius: 30rpx !important;
  line-height: 1.4 !important;
}

.share-btn::after { border: none; }

/* 领取奖励浮层 */
.reward-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.reward-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 50rpx;
  text-align: center;
  box-shadow: 0 16rpx 40rpx rgba(0,0,0,0.2);
}

.reward-emoji {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.reward-text {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}
