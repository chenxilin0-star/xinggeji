.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #2D9CDB 0%, #56CCF2 60%, #E8F8FF 100%);
  padding: 30rpx;
  padding-bottom: 60rpx;
}

.loading { text-align: center; padding: 200rpx 0; color: #fff; }

/* 综合评估 */
.overview-card {
  text-align: center;
  padding: 50rpx 30rpx 40rpx;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
}

.ov-emoji { font-size: 80rpx; }
.ov-label { font-size: 26rpx; color: rgba(255,255,255,0.8); margin-top: 10rpx; }
.ov-level { font-size: 44rpx; font-weight: bold; color: #fff; margin-top: 6rpx; }
.ov-score { font-size: 24rpx; color: rgba(255,255,255,0.7); margin-top: 10rpx; }

/* 卡片 */
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 6rpx 24rpx rgba(45,156,219,0.12);
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

/* 柱状图 */
.chart-area {
  position: relative;
  padding: 10rpx 0;
}

.chart-grid {
  position: absolute;
  top: 10rpx;
  left: 0;
  right: 0;
  bottom: 120rpx;
}

.grid-line {
  position: absolute;
  left: 0;
  right: 0;
  border-top: 1rpx dashed #eee;
}

.grid-text {
  position: absolute;
  right: 0;
  top: -16rpx;
  font-size: 18rpx;
  color: #bbb;
}

.bar-chart {
  display: flex;
  justify-content: space-around;
  align-items: flex-end;
  height: 320rpx;
  padding-bottom: 120rpx;
  position: relative;
}

.bar-group {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 30%;
}

.bar-wrapper {
  width: 80rpx;
  height: 280rpx;
  background: #f5f5f5;
  border-radius: 12rpx 12rpx 0 0;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  overflow: hidden;
  position: relative;
}

.bar-fill {
  width: 100%;
  border-radius: 12rpx 12rpx 0 0;
  transition: height 0.6s ease;
  position: relative;
  min-height: 8rpx;
}

.bar-score {
  position: absolute;
  top: -36rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
}

.bar-name {
  font-size: 26rpx;
  color: #333;
  font-weight: bold;
  margin-top: 12rpx;
}

.bar-level {
  font-size: 22rpx;
  margin-top: 6rpx;
  font-weight: 500;
}

/* 图例 */
.legend {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
  justify-content: center;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 20rpx;
  color: #888;
}

.legend-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
}

/* 警告 */
.alert-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.alert-item {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
}

.alert-icon { font-size: 24rpx; flex-shrink: 0; }
.alert-text { font-size: 26rpx; color: #555; line-height: 1.6; }

/* 建议 */
.tips-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.tip-num {
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, #2D9CDB, #56CCF2);
  border-radius: 50%;
  color: #fff;
  font-size: 22rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.tip-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
  padding-top: 6rpx;
}

/* 热线 */
.hotline-card {
  background: #fff;
  border-left: 8rpx solid #2D9CDB;
}

.hotline-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.hotline-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 20rpx;
  background: #F0F9FF;
  border-radius: 12rpx;
}

.hl-name { font-size: 24rpx; color: #555; flex: 1; }
.hl-num { font-size: 26rpx; color: #2D9CDB; font-weight: bold; }

.hotline-note {
  display: block;
  text-align: center;
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #999;
}

/* 按钮 */
.actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 20rpx;
}

.btn-share {
  background: linear-gradient(135deg, #2D9CDB, #56CCF2);
  color: #fff;
  border: none;
  box-shadow: 0 6rpx 20rpx rgba(45,156,219,0.35);
}
.btn-retake {
  background: #fff;
  color: #2D9CDB;
  border: 2rpx solid #2D9CDB;
}
.btn-home {
  background: rgba(255,255,255,0.5);
  color: #2D9CDB;
  border: none;
}

.btn-share, .btn-retake, .btn-home {
  padding: 28rpx 0;
  border-radius: 50rpx;
  font-size: 30rpx;
  text-align: center;
  font-weight: 500;
}

.btn-share::after, .btn-retake::after, .btn-home::after { border: none; }
