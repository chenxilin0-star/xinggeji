.container {
  min-height: 100vh;
  background: linear-gradient(160deg, #2D9CDB 0%, #56CCF2 40%, #A8E0F8 80%, #E8F6FD 100%);
  padding: 0 30rpx 60rpx;
  padding-bottom: 80rpx;
}

.loading { text-align: center; padding: 200rpx 0; color: #fff; }

/* 综合评估 */
.overview-card {
  text-align: center;
  padding: 60rpx 30rpx 50rpx;
  border-radius: 0 0 40rpx 40rpx;
}

.ov-emoji { font-size: 80rpx; }
.ov-label { font-size: 24rpx; color: rgba(255,255,255,0.8); margin-top: 10rpx; }
.ov-level { font-size: 44rpx; font-weight: 900; color: #fff; margin-top: 6rpx; }
.ov-score { font-size: 24rpx; color: rgba(255,255,255,0.7); margin-top: 12rpx; }

/* 卡片 */
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(45,156,219,0.1);
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  padding-bottom: 14rpx;
  border-bottom: 2rpx solid #e8f4f8;
}

/* 柱状图 */
.chart-area {
  position: relative;
  padding: 20rpx 0 10rpx;
}

.chart-grid {
  position: absolute;
  top: 20rpx;
  left: 0;
  right: 0;
  bottom: 70rpx;
}

.grid-line {
  position: absolute;
  left: 0;
  right: 0;
  border-top: 1rpx dashed #eee;
}

.grid-text {
  position: absolute;
  right: 0;
  top: -18rpx;
  font-size: 18rpx;
  color: #bbb;
}

.bar-chart {
  display: flex;
  justify-content: space-around;
  align-items: flex-end;
  height: 360rpx;
  padding-bottom: 70rpx;
  position: relative;
}

.bar-group {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 30%;
}

.bar-wrapper {
  width: 90rpx;
  height: 280rpx;
  background: #f5f5f5;
  border-radius: 14rpx 14rpx 0 0;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  overflow: hidden;
  position: relative;
}

.bar-fill {
  width: 100%;
  border-radius: 14rpx 14rpx 0 0;
  transition: height 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  min-height: 10rpx;
}

.bar-score {
  position: absolute;
  top: -38rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  background: #fff;
  padding: 2rpx 12rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.bar-name {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  margin-top: 14rpx;
}

.bar-level {
  font-size: 22rpx;
  margin-top: 6rpx;
  font-weight: 600;
}

/* 图例 */
.legend {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 24rpx;
  justify-content: center;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #888;
}

.legend-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 4rpx;
}

/* 警告 */
.alert-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.alert-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 16rpx 20rpx;
  background: #FFF5F5;
  border-radius: 14rpx;
}

.alert-icon { font-size: 24rpx; flex-shrink: 0; }
.alert-text { font-size: 26rpx; color: #555; line-height: 1.7; }

/* 建议 */
.tips-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.tip-num {
  width: 42rpx;
  height: 42rpx;
  background: linear-gradient(135deg, #2D9CDB, #56CCF2);
  border-radius: 50%;
  color: #fff;
  font-size: 22rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.tip-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.7;
  padding-top: 6rpx;
}

/* 热线 */
.hotline-card {
  background: #fff;
  border-left: 8rpx solid #2D9CDB;
}

.hotline-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.hotline-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 20rpx;
  background: #F0F9FF;
  border-radius: 14rpx;
}

.hl-name { font-size: 24rpx; color: #555; flex: 1; }
.hl-num { font-size: 26rpx; color: #2D9CDB; font-weight: bold; }

.hotline-note {
  display: block;
  text-align: center;
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #999;
}

/* 按钮 */
.actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 24rpx;
}

.btn-share {
  background: linear-gradient(135deg, #2D9CDB, #56CCF2);
  color: #fff;
  border: none;
  box-shadow: 0 6rpx 24rpx rgba(45,156,219,0.3);
}

.btn-retake {
  background: #fff;
  color: #2D9CDB;
  border: 2rpx solid #2D9CDB;
}

.btn-home {
  background: transparent;
  color: rgba(255,255,255,0.7);
  border: none;
  font-weight: 400;
}

.btn-share, .btn-retake, .btn-home {
  padding: 26rpx 0;
  border-radius: 50rpx;
  font-size: 28rpx;
  text-align: center;
  font-weight: 600;
}

.btn-share::after, .btn-retake::after, .btn-home::after { border: none; }
