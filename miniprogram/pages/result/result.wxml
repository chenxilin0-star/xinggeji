<view class="container">
  <!-- 顶部标题 -->
  <view class="header">
    <text class="test-title">{{testEmojis[testId]}} {{testTitles[testId]}}</text>
  </view>

  <!-- 结果卡片 -->
  <view class="result-card">
    <view class="result-emoji">{{resultData.result.emoji}}</view>
    <view class="result-type">{{resultData.result.type_name}}</view>
    <view class="result-desc">{{resultData.result.description}}</view>
  </view>

  <!-- 雷达图区域 -->
  <view class="radar-card" wx:if="{{dimensions.length >= 3}}">
    <view class="card-title">维度分析</view>
    <view class="radar-wrapper">
      <canvas type="2d" canvas-id="radarCanvas" class="radar-canvas" bindtouchstart="onCanvasTouch"></canvas>
    </view>
  </view>

  <!-- MBTI四宫格 -->
  <view class="mbti-card" wx:if="{{testId === 'mbti'}}">
    <view class="card-title">MBTI四宫格</view>
    <view class="mbti-grid">
      <view class="mbti-row">
        <view class="mbti-cell {{resultData.result.resultCode.charAt(0) === 'E' ? 'active' : ''}}">
          <text class="cell-letter">E</text>
          <text class="cell-name">外向型</text>
        </view>
        <view class="mbti-cell {{resultData.result.resultCode.charAt(0) === 'I' ? 'active' : ''}}">
          <text class="cell-letter">I</text>
          <text class="cell-name">内向型</text>
        </view>
      </view>
      <view class="mbti-row">
        <view class="mbti-cell {{resultData.result.resultCode.charAt(1) === 'S' ? 'active' : ''}}">
          <text class="cell-letter">S</text>
          <text class="cell-name">实感型</text>
        </view>
        <view class="mbti-cell {{resultData.result.resultCode.charAt(1) === 'N' ? 'active' : ''}}">
          <text class="cell-letter">N</text>
          <text class="cell-name">直觉型</text>
        </view>
      </view>
      <view class="mbti-row">
        <view class="mbti-cell {{resultData.result.resultCode.charAt(2) === 'T' ? 'active' : ''}}">
          <text class="cell-letter">T</text>
          <text class="cell-name">理性型</text>
        </view>
        <view class="mbti-cell {{resultData.result.resultCode.charAt(2) === 'F' ? 'active' : ''}}">
          <text class="cell-letter">F</text>
          <text class="cell-name">情感型</text>
        </view>
      </view>
      <view class="mbti-row">
        <view class="mbti-cell {{resultData.result.resultCode.charAt(3) === 'J' ? 'active' : ''}}">
          <text class="cell-letter">J</text>
          <text class="cell-name">判断型</text>
        </view>
        <view class="mbti-cell {{resultData.result.resultCode.charAt(3) === 'P' ? 'active' : ''}}">
          <text class="cell-letter">P</text>
          <text class="cell-name">感知型</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 维度详情列表 -->
  <view class="detail-card" wx:if="{{dimensions.length > 0 && testId !== 'mbti'}}">
    <view class="card-title">详细分析</view>
    <view class="detail-list">
      <view class="detail-item" wx:for="{{dimensions}}" wx:key="name">
        <view class="detail-header">
          <text class="detail-name">{{item.name}}</text>
          <text class="detail-value">{{item.value}}分</text>
        </view>
        <view class="detail-bar">
          <view class="detail-fill" style="width: {{item.value}}%"></view>
        </view>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="actions">
    <button class="btn-share" open-type="share">分享结果</button>
    <button class="btn-retake" bindtap="retakeTest">再做一次</button>
    <button class="btn-home" bindtap="backToHome">返回首页</button>
  </view>
</view>
