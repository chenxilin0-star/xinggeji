<view class="container">
  <!-- 顶部标题 -->
  <view class="header">
    <text class="test-title">{{testEmojis[testId]}} {{testTitles[testId]}}</text>
  </view>

  <!-- 结果卡片 -->
  <view class="result-card">
    <view class="result-emoji">{{resultData.result.emoji}}</view>
    <view class="result-type">{{resultData.result.type_name}}</view>
    <view class="result-desc">{{resultData.result.description}}</view>
  </view>

  <!-- 维度分析区域 - 改用进度条展示 -->
  <view class="analysis-card" wx:if="{{dimensions.length > 0}}">
    <view class="card-title">维度分析</view>
    
    <!-- MBTI四宫格展示 -->
    <view class="mbti-grid" wx:if="{{testId === 'mbti'}}">
      <view class="dimension-pair">
        <view class="dim-row">
          <view class="dim-cell {{resultData.result.resultCode.charAt(0) === 'E' ? 'active' : ''}}">
            <text class="dim-letter">E</text>
            <text class="dim-label">外向</text>
          </view>
          <view class="dim-cell {{resultData.result.resultCode.charAt(0) === 'I' ? 'active' : ''}}">
            <text class="dim-letter">I</text>
            <text class="dim-label">内向</text>
          </view>
        </view>
        <view class="dim-progress">
          <view class="progress-bar-horizontal">
            <view class="progress-fill E" style="width: {{mbtiScores.EP}}%"></view>
            <view class="progress-fill I" style="width: {{mbtiScores.IP}}%"></view>
          </view>
        </view>
      </view>
      
      <view class="dimension-pair">
        <view class="dim-row">
          <view class="dim-cell {{resultData.result.resultCode.charAt(1) === 'S' ? 'active' : ''}}">
            <text class="dim-letter">S</text>
            <text class="dim-label">实感</text>
          </view>
          <view class="dim-cell {{resultData.result.resultCode.charAt(1) === 'N' ? 'active' : ''}}">
            <text class="dim-letter">N</text>
            <text class="dim-label">直觉</text>
          </view>
        </view>
        <view class="dim-progress">
          <view class="progress-bar-horizontal">
            <view class="progress-fill S" style="width: {{mbtiScores.SP}}%"></view>
            <view class="progress-fill N" style="width: {{mbtiScores.NP}}%"></view>
          </view>
        </view>
      </view>
      
      <view class="dimension-pair">
        <view class="dim-row">
          <view class="dim-cell {{resultData.result.resultCode.charAt(2) === 'T' ? 'active' : ''}}">
            <text class="dim-letter">T</text>
            <text class="dim-label">理性</text>
          </view>
          <view class="dim-cell {{resultData.result.resultCode.charAt(2) === 'F' ? 'active' : ''}}">
            <text class="dim-letter">F</text>
            <text class="dim-label">情感</text>
          </view>
        </view>
        <view class="dim-progress">
          <view class="progress-bar-horizontal">
            <view class="progress-fill T" style="width: {{mbtiScores.TP}}%"></view>
            <view class="progress-fill F" style="width: {{mbtiScores.FP}}%"></view>
          </view>
        </view>
      </view>
      
      <view class="dimension-pair">
        <view class="dim-row">
          <view class="dim-cell {{resultData.result.resultCode.charAt(3) === 'J' ? 'active' : ''}}">
            <text class="dim-letter">J</text>
            <text class="dim-label">判断</text>
          </view>
          <view class="dim-cell {{resultData.result.resultCode.charAt(3) === 'P' ? 'active' : ''}}">
            <text class="dim-letter">P</text>
            <text class="dim-label">感知</text>
          </view>
        </view>
        <view class="dim-progress">
          <view class="progress-bar-horizontal">
            <view class="progress-fill J" style="width: {{mbtiScores.JP}}%"></view>
            <view class="progress-fill P" style="width: {{mbtiScores.PP}}%"></view>
          </view>
        </view>
      </view>
    </view>

    <!-- 非MBTI测试的维度展示 -->
    <view class="dimensions-list" wx:if="{{testId !== 'mbti'}}">
      <view class="dimension-item" wx:for="{{dimensions}}" wx:key="name">
        <view class="dimension-header">
          <view class="dimension-name">{{item.name}}</view>
          <view class="dimension-score">{{item.value}}分</view>
        </view>
        <view class="dimension-bar">
          <view class="dimension-value" style="width: {{item.value}}%;"></view>
        </view>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="actions">
    <button class="btn-share" open-type="share">分享结果</button>
    <button class="btn-retake" bindtap="retakeTest">再做一次</button>
    <button class="btn-home" bindtap="backToHome">返回首页</button>
  </view>
</view>
