.container {
  padding: 30rpx;
  min-height: 100vh;
}

.header {
  text-align: center;
  padding: 30rpx 0;
}

.test-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.result-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(108, 92, 231, 0.2);
}

.result-emoji {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.result-type {
  font-size: 48rpx;
  font-weight: bold;
  color: #6C5CE7;
  margin-bottom: 20rpx;
}

.result-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.radar-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  margin-top: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(108, 92, 231, 0.15);
}

.radar-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
  text-align: center;
}

.radar-placeholder {
  width: 100%;
  height: 300rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.radar-canvas {
  width: 300rpx;
  height: 300rpx;
}

.dimensions-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.dimension-item {
  display: flex;
  align-items: center;
}

.dimension-name {
  width: 120rpx;
  font-size: 24rpx;
  color: #666;
}

.dimension-bar {
  flex: 1;
  height: 20rpx;
  background: #f0f0f0;
  border-radius: 10rpx;
  overflow: hidden;
  margin: 0 15rpx;
}

.dimension-value {
  height: 100%;
  border-radius: 10rpx;
  transition: width 0.5s ease;
}

.dimension-score {
  width: 80rpx;
  font-size: 24rpx;
  color: #999;
  text-align: right;
}

.actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 40rpx;
}

.btn-share, .btn-retake, .btn-home {
  padding: 25rpx 0;
  border-radius: 50rpx;
  font-size: 28rpx;
  text-align: center;
}

.btn-share {
  background: linear-gradient(135deg, #6C5CE7 0%, #a29bfe 100%);
  color: #fff;
  box-shadow: 0 4rpx 15rpx rgba(108, 92, 231, 0.4);
  border: none;
}

.btn-retake {
  background: #fff;
  color: #6C5CE7;
  border: 2rpx solid #6C5CE7;
}

.btn-home {
  background: #f5f5f5;
  color: #666;
  border: none;
}

.btn-share::after, .btn-retake::after, .btn-home::after {
  border: none;
}
