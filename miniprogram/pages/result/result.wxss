.container {
  padding: 30rpx;
  min-height: 100vh;
  padding-bottom: 50rpx;
}

.header {
  text-align: center;
  padding: 30rpx 0;
}

.test-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.result-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  box-shadow: 0 8rpx 30rpx rgba(108, 92, 231, 0.25);
  margin-bottom: 30rpx;
}

.result-emoji {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.result-type {
  font-size: 52rpx;
  font-weight: bold;
  color: #6C5CE7;
  margin-bottom: 20rpx;
}

.result-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.radar-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(108, 92, 231, 0.15);
}

.radar-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
  text-align: center;
}

.radar-container {
  width: 100%;
  height: 340rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.radar-canvas {
  width: 300px;
  height: 300px;
}

.dimensions-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.dimension-item {
  display: flex;
  flex-direction: column;
}

.dimension-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.dimension-name {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.dimension-score {
  font-size: 24rpx;
  color: #6C5CE7;
  font-weight: bold;
}

.dimension-bar {
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
}

.dimension-value {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.8s ease;
}

/* MBTI专属四宫格 */
.mbti-detail {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(108, 92, 231, 0.15);
}

.mbti-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
  text-align: center;
}

.mbti-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.mbti-cell {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  background: #f8f7ff;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.mbti-cell.active {
  background: linear-gradient(135deg, #6C5CE7 0%, #a29bfe 100%);
  border-color: #6C5CE7;
}

.mbti-cell.active .cell-letter,
.mbti-cell.active .cell-label {
  color: #fff;
}

.cell-letter {
  font-size: 40rpx;
  font-weight: bold;
  color: #6C5CE7;
  margin-bottom: 8rpx;
}

.cell-label {
  font-size: 22rpx;
  color: #999;
}

/* 操作按钮 */
.actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 30rpx;
}

.btn-share, .btn-retake, .btn-home {
  padding: 28rpx 0;
  border-radius: 50rpx;
  font-size: 30rpx;
  text-align: center;
  font-weight: 500;
}

.btn-share {
  background: linear-gradient(135deg, #6C5CE7 0%, #a29bfe 100%);
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(108, 92, 231, 0.4);
  border: none;
}

.btn-retake {
  background: #fff;
  color: #6C5CE7;
  border: 2rpx solid #6C5CE7;
}

.btn-home {
  background: #f5f5f5;
  color: #666;
  border: none;
}

.btn-share::after, .btn-retake::after, .btn-home::after {
  border: none;
}
