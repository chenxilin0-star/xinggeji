.container {
  padding: 30rpx;
  min-height: 100vh;
  padding-bottom: 50rpx;
}

.header {
  text-align: center;
  padding: 30rpx 0;
}

.test-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.result-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  box-shadow: 0 8rpx 30rpx rgba(108, 92, 231, 0.25);
  margin-bottom: 30rpx;
}

.result-emoji {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.result-type {
  font-size: 56rpx;
  font-weight: bold;
  color: #6C5CE7;
  margin-bottom: 20rpx;
}

.result-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.analysis-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(108, 92, 231, 0.15);
}

.card-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
  text-align: center;
}

/* MBTI四宫格 */
.mbti-grid {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.dimension-pair {
  background: #f8f7ff;
  border-radius: 16rpx;
  padding: 20rpx;
}

.dim-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.dim-cell {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  border-radius: 12rpx;
  background: #fff;
  border: 2rpx solid #e8e6f5;
  transition: all 0.3s ease;
}

.dim-cell.active {
  background: linear-gradient(135deg, #6C5CE7 0%, #a29bfe 100%);
  border-color: #6C5CE7;
}

.dim-cell.active .dim-letter,
.dim-cell.active .dim-label {
  color: #fff;
}

.dim-letter {
  font-size: 32rpx;
  font-weight: bold;
  color: #6C5CE7;
  margin-right: 8rpx;
}

.dim-label {
  font-size: 24rpx;
  color: #666;
}

.dim-progress {
  margin-top: 8rpx;
}

.progress-bar-horizontal {
  height: 12rpx;
  background: #e8e6f5;
  border-radius: 6rpx;
  display: flex;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  transition: width 0.5s ease;
}

.progress-fill.E,
.progress-fill.T,
.progress-fill.S,
.progress-fill.J {
  background: linear-gradient(90deg, #6C5CE7, #a29bfe);
}

.progress-fill.I,
.progress-fill.F,
.progress-fill.N,
.progress-fill.P {
  background: #e8e6f5;
}

/* 非MBTI维度列表 */
.dimensions-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.dimension-item {
  display: flex;
  flex-direction: column;
}

.dimension-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.dimension-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.dimension-score {
  font-size: 26rpx;
  color: #6C5CE7;
  font-weight: bold;
}

.dimension-bar {
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
}

.dimension-value {
  height: 100%;
  background: linear-gradient(90deg, #6C5CE7, #a29bfe);
  border-radius: 8rpx;
  transition: width 0.8s ease;
}

/* 操作按钮 */
.actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 30rpx;
}

.btn-share, .btn-retake, .btn-home {
  padding: 28rpx 0;
  border-radius: 50rpx;
  font-size: 30rpx;
  text-align: center;
  font-weight: 500;
}

.btn-share {
  background: linear-gradient(135deg, #6C5CE7 0%, #a29bfe 100%);
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(108, 92, 231, 0.4);
  border: none;
}

.btn-retake {
  background: #fff;
  color: #6C5CE7;
  border: 2rpx solid #6C5CE7;
}

.btn-home {
  background: #f5f5f5;
  color: #666;
  border: none;
}

.btn-share::after, .btn-retake::after, .btn-home::after {
  border: none;
}
