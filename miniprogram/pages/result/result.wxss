.container {
  padding: 30rpx;
  min-height: 100vh;
  padding-bottom: 50rpx;
}

.header {
  text-align: center;
  padding: 30rpx 0;
}

.test-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.result-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
  text-align: center;
  box-shadow: 0 8rpx 30rpx rgba(108, 92, 231, 0.2);
  margin-bottom: 30rpx;
}

.result-emoji {
  font-size: 90rpx;
  margin-bottom: 16rpx;
}

.result-type {
  font-size: 48rpx;
  font-weight: bold;
  color: #6C5CE7;
  margin-bottom: 16rpx;
}

.result-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.radar-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(108, 92, 231, 0.15);
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  text-align: center;
}

.radar-wrapper {
  width: 100%;
  height: 400rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.radar-canvas {
  width: 350rpx;
  height: 350rpx;
}

/* MBTI四宫格 */
.mbti-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(108, 92, 231, 0.15);
}

.mbti-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.mbti-row {
  display: flex;
  gap: 16rpx;
}

.mbti-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  background: #f8f7ff;
  border-radius: 16rpx;
  border: 2rpx solid #e8e6f5;
  transition: all 0.3s ease;
}

.mbti-cell.active {
  background: linear-gradient(135deg, #6C5CE7 0%, #a29bfe 100%);
  border-color: #6C5CE7;
}

.mbti-cell.active .cell-letter,
.mbti-cell.active .cell-name {
  color: #fff;
}

.cell-letter {
  font-size: 40rpx;
  font-weight: bold;
  color: #6C5CE7;
  margin-bottom: 6rpx;
}

.cell-name {
  font-size: 22rpx;
  color: #888;
}

/* 维度详情列表 */
.detail-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(108, 92, 231, 0.15);
}

.detail-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.detail-item {
  display: flex;
  flex-direction: column;
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.detail-name {
  font-size: 28rpx;
  color: #333;
}

.detail-value {
  font-size: 26rpx;
  color: #6C5CE7;
  font-weight: bold;
}

.detail-bar {
  height: 14rpx;
  background: #f0f0f0;
  border-radius: 7rpx;
  overflow: hidden;
}

.detail-fill {
  height: 100%;
  background: linear-gradient(90deg, #6C5CE7, #a29bfe);
  border-radius: 7rpx;
  transition: width 0.5s ease;
}

/* 操作按钮 */
.actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 20rpx;
}

.btn-share, .btn-retake, .btn-home {
  padding: 28rpx 0;
  border-radius: 50rpx;
  font-size: 30rpx;
  text-align: center;
  font-weight: 500;
}

.btn-share {
  background: linear-gradient(135deg, #6C5CE7 0%, #a29bfe 100%);
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(108, 92, 231, 0.35);
  border: none;
}

.btn-retake {
  background: #fff;
  color: #6C5CE7;
  border: 2rpx solid #6C5CE7;
}

.btn-home {
  background: #f5f5f5;
  color: #666;
  border: none;
}

.btn-share::after, .btn-retake::after, .btn-home::after {
  border: none;
}
