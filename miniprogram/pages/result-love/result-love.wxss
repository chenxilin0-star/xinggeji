.container {
  min-height: 100vh;
  background: linear-gradient(160deg, #FF6B9D 0%, #FF9EB5 40%, #FFE0EB 80%, #FFF5F9 100%);
  padding: 0 30rpx 60rpx;
  padding-bottom: 80rpx;
}

.loading { text-align: center; padding: 200rpx 0; color: #fff; }

/* 仪表盘区域 */
.gauge-section {
  text-align: center;
  padding: 60rpx 0 30rpx;
}

.gauge-title {
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
  font-weight: 600;
}

.gauge-wrapper {
  width: 100%;
  height: 300rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.gauge-canvas {
  width: 320rpx;
  height: 300rpx;
}

.score-display {
  margin-top: -30rpx;
}

.score-num {
  font-size: 80rpx;
  font-weight: 900;
  color: #FF6B9D;
}

.score-total {
  font-size: 28rpx;
  color: #FF6B9D99;
}

.level-badge {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-top: 8rpx;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.love-tag {
  display: inline-block;
  margin-top: 14rpx;
  padding: 10rpx 32rpx;
  background: rgba(255,255,255,0.3);
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #fff;
  border: 1rpx solid rgba(255,255,255,0.2);
}

/* 卡片 */
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(255,107,157,0.08);
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 28rpx;
  padding-bottom: 14rpx;
  border-bottom: 2rpx solid #FFF0F5;
}

/* 四维度 */
.dim-list {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.dim-item {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.dim-header {
  display: flex;
  justify-content: space-between;
}

.dim-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.dim-score {
  font-size: 26rpx;
  color: #FF6B9D;
  font-weight: bold;
}

.dim-bar-bg {
  height: 18rpx;
  background: #FFF0F5;
  border-radius: 9rpx;
  overflow: hidden;
}

.dim-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF6B9D, #FFB3C6);
  border-radius: 9rpx;
  transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}

.dim-desc {
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
  padding-left: 4rpx;
}

/* 处方卡片 */
.rx-card {
  border-left: 8rpx solid #FF6B9D;
}

.rx-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.rx-item {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
}

.rx-num {
  width: 44rpx;
  height: 44rpx;
  background: linear-gradient(135deg, #FF6B9D, #FFB3C6);
  border-radius: 50%;
  color: #fff;
  font-size: 22rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.rx-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.7;
  padding-top: 6rpx;
}

/* 按钮 */
.actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 24rpx;
}

.btn-share {
  background: linear-gradient(135deg, #FF6B9D, #FFB3C6);
  color: #fff;
  border: none;
  box-shadow: 0 6rpx 24rpx rgba(255,107,157,0.3);
}

.btn-retake {
  background: #fff;
  color: #FF6B9D;
  border: 2rpx solid #FF6B9D;
}

.btn-home {
  background: transparent;
  color: rgba(255,255,255,0.7);
  border: none;
  font-weight: 400;
}

.btn-share, .btn-retake, .btn-home {
  padding: 26rpx 0;
  border-radius: 50rpx;
  font-size: 28rpx;
  text-align: center;
  font-weight: 600;
}

.btn-share::after, .btn-retake::after, .btn-home::after { border: none; }
