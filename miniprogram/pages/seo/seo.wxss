.container {
  padding: 30rpx;
  min-height: 100vh;
  padding-bottom: 50rpx;
}

.header {
  text-align: center;
  padding: 40rpx 0 50rpx;
}

.logo-area {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.logo-icon {
  font-size: 56rpx;
  margin-right: 12rpx;
}

.logo-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 4rpx;
}

.slogan {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.75);
}

.test-grid {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 50rpx;
}

.test-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(108, 92, 231, 0.12);
  transition: all 0.2s ease;
}

.test-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 12rpx rgba(108, 92, 231, 0.08);
}

.card-icon {
  font-size: 56rpx;
  margin-right: 24rpx;
}

.card-content {
  flex: 1;
}

.card-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.card-desc {
  display: block;
  font-size: 26rpx;
  color: #888;
  margin-bottom: 12rpx;
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag {
  font-size: 20rpx;
  color: #6C5CE7;
  background: rgba(108, 92, 231, 0.08);
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}

.card-arrow {
  font-size: 44rpx;
  color: #d0cce8;
  margin-left: 16rpx;
}

.keywords-section {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 20rpx;
  text-align: center;
}

.keywords-cloud {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 16rpx;
}

.keyword {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  background: rgba(255, 255, 255, 0.15);
  padding: 12rpx 20rpx;
  border-radius: 30rpx;
  transition: all 0.2s ease;
}

.keyword:active {
  background: rgba(255, 255, 255, 0.25);
  transform: scale(0.95);
}

.footer {
  text-align: center;
  padding: 30rpx 0;
}

.footer-text {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 8rpx;
}

.footer-desc {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.35);
}

.hot-badge {
  display: inline-block;
  font-size: 22rpx;
  color: #FF6B6B;
  background: rgba(255,107,107,0.1);
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  margin-bottom: 8rpx;
  font-weight: 600;
}

.hot-tag {
  color: #FF6B6B !important;
  background: rgba(255,107,107,0.1) !important;
  font-weight: 600;
}

.hot-kw {
  color: #FFD93D !important;
  background: rgba(255,217,61,0.2) !important;
  font-weight: 600;
}
