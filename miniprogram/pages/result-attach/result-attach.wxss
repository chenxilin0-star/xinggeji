.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #BB6BD9 0%, #EFC5F5 60%, #FDF2FF 100%);
  padding: 30rpx;
  padding-bottom: 60rpx;
}

.loading { text-align: center; padding: 200rpx 0; color: #fff; }

/* 顶部 */
.result-hero {
  text-align: center;
  padding: 60rpx 30rpx 40rpx;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
}

.hero-emoji { font-size: 100rpx; }
.hero-name { font-size: 44rpx; font-weight: bold; color: #fff; margin-top: 10rpx; }
.hero-tagline { font-size: 28rpx; color: rgba(255,255,255,0.85); margin-top: 10rpx; font-style: italic; }

/* 卡片 */
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 6rpx 24rpx rgba(187,107,217,0.12);
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

/* 四象限图 */
.quadrant-wrap {
  position: relative;
  padding: 30rpx 20rpx 10rpx;
}

.q-label {
  position: absolute;
  font-size: 20rpx;
  color: #999;
}
.q-top { top: 0; left: 50%; transform: translateX(-50%); }
.q-bottom { bottom: 0; left: 50%; transform: translateX(-50%); }
.q-left { left: 0; top: 50%; transform: translateY(-50%) rotate(-90deg); transform-origin: center; }
.q-right { right: 0; top: 50%; transform: translateY(-50%) rotate(90deg); transform-origin: center; }

.quadrant-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.q-cell {
  width: calc(50% - 4rpx);
  padding: 28rpx 16rpx;
  background: #fafafa;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  transition: all 0.3s ease;
}

.q-cell.q-active {
  border-width: 3rpx;
  transform: scale(1.02);
}

.q-emoji { font-size: 36rpx; }
.q-name { font-size: 22rpx; color: #666; font-weight: bold; }

/* 维度得分 */
.dim-section {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.dim-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.dim-label {
  font-size: 26rpx;
  color: #555;
  width: 130rpx;
  flex-shrink: 0;
}

.dim-bar-bg {
  flex: 1;
  height: 18rpx;
  background: #f0f0f0;
  border-radius: 9rpx;
  overflow: hidden;
}

.dim-bar-fill {
  height: 100%;
  border-radius: 9rpx;
  transition: width 0.5s ease;
}

.dim-val {
  font-size: 24rpx;
  color: #333;
  font-weight: bold;
  width: 70rpx;
  text-align: right;
}

/* 概述 */
.desc-text { font-size: 28rpx; color: #555; line-height: 1.8; }

/* 建议列表 */
.insight-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.insight-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.insight-dot, .insight-num {
  font-size: 22rpx;
  flex-shrink: 0;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.insight-num {
  border-radius: 50%;
  color: #fff;
  font-weight: bold;
  font-size: 22rpx;
}

.insight-text {
  font-size: 26rpx;
  color: #555;
  line-height: 1.6;
  padding-top: 8rpx;
}

/* 与不同类型相处 */
.with-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.with-item {
  padding: 16rpx 20rpx;
  background: #fafafa;
  border-radius: 12rpx;
}

.with-label {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.with-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

/* 按钮 */
.actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 20rpx;
}

.btn-share {
  background: linear-gradient(135deg, #BB6BD9, #EFC5F5);
  color: #fff;
  border: none;
  box-shadow: 0 6rpx 20rpx rgba(187,107,217,0.35);
}
.btn-retake {
  background: #fff;
  color: #BB6BD9;
  border: 2rpx solid #BB6BD9;
}
.btn-home {
  background: rgba(255,255,255,0.5);
  color: #BB6BD9;
  border: none;
}

.btn-share, .btn-retake, .btn-home {
  padding: 28rpx 0;
  border-radius: 50rpx;
  font-size: 30rpx;
  text-align: center;
  font-weight: 500;
}

.btn-share::after, .btn-retake::after, .btn-home::after { border: none; }
