page {
  background: #9B59B6;
}

.container {
  min-height: 100vh;
  background: linear-gradient(160deg, #9B59B6 0%, #C39BD3 40%, #E8D5F0 80%, #FAF0FF 100%);
  padding: 0 30rpx 60rpx;
  padding-bottom: 80rpx;
}

.loading { text-align: center; padding: 200rpx 0; color: #fff; }

/* 顶部 */
.result-hero {
  text-align: center;
  padding: 70rpx 30rpx 40rpx;
  border-radius: 0 0 40rpx 40rpx;
}

.hero-emoji { font-size: 90rpx; }
.hero-name { font-size: 44rpx; font-weight: 900; color: #fff; margin-top: 14rpx; }
.hero-tagline { font-size: 26rpx; color: rgba(255,255,255,0.85); margin-top: 10rpx; font-style: italic; }

/* 卡片 */
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(155,89,182,0.1);
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  padding-bottom: 14rpx;
  border-bottom: 2rpx solid #f3e8f3;
 }

/* 四象限图 */
.quadrant-wrap {
  position: relative;
  padding: 40rpx 20rpx 10rpx;
}

.q-label {
  position: absolute;
  font-size: 20rpx;
  color: #aaa;
  font-weight: 500;
}
.q-top { top: 10rpx; left: 50%; transform: translateX(-50%); }
.q-bottom { bottom: 10rpx; left: 50%; transform: translateX(-50%); }
.q-left { left: -4rpx; top: 50%; transform: translateY(-50%) rotate(-90deg); }
.q-right { right: -4rpx; top: 50%; transform: translateY(-50%) rotate(90deg); }

.quadrant-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.q-cell {
  width: calc(50% - 4rpx);
  padding: 30rpx 16rpx;
  background: #fafafa;
  border: 2rpx solid #eee;
  border-radius: 14rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  transition: all 0.3s ease;
}

.q-cell.q-active {
  border-width: 3rpx;
  transform: scale(1.04);
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.q-emoji { font-size: 40rpx; }
.q-name { font-size: 24rpx; color: #666; font-weight: bold; }

/* 维度得分 */
.dim-section {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.dim-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.dim-label {
  font-size: 26rpx;
  color: #555;
  width: 130rpx;
  flex-shrink: 0;
}

.dim-bar-bg {
  flex: 1;
  height: 20rpx;
  background: #f0f0f0;
  border-radius: 10rpx;
  overflow: hidden;
}

.dim-bar-fill {
  height: 100%;
  border-radius: 10rpx;
  transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}

.dim-val {
  font-size: 24rpx;
  color: #333;
  font-weight: bold;
  width: 80rpx;
  text-align: right;
}

/* 概述 */
.desc-text { font-size: 28rpx; color: #555; line-height: 1.9; text-align: justify; }

/* 建议 */
.insight-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.insight-item {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.insight-num {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  color: #fff;
  font-weight: bold;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.insight-text {
  font-size: 26rpx;
  color: #555;
  line-height: 1.7;
  padding-top: 6rpx;
}

/* 与不同类型相处 */
.with-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.with-item {
  padding: 18rpx 22rpx;
  background: #fafafa;
  border-radius: 14rpx;
}

.with-label {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.with-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.7;
}

/* 按钮 */
.actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 24rpx;
}

.btn-share {
  background: linear-gradient(135deg, #9B59B6, #C39BD3);
  color: #fff;
  border: none;
  box-shadow: 0 6rpx 24rpx rgba(155,89,182,0.3);
}

.btn-retake {
  background: #fff;
  color: #9B59B6;
  border: 2rpx solid #9B59B6;
}

.btn-home {
  background: transparent;
  color: rgba(255,255,255,0.7);
  border: none;
  font-weight: 400;
}

.btn-share, .btn-retake, .btn-home {
  padding: 26rpx 0;
  border-radius: 50rpx;
  font-size: 28rpx;
  text-align: center;
  font-weight: 600;
}

.btn-share::after, .btn-retake::after, .btn-home::after { border: none; }
