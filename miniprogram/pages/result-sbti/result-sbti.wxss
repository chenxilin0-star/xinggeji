.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #2ECC71 0%, #f0f9f4 30%, #f5f5f5 100%);
  padding-bottom: 40rpx;
}

.mode-kicker {
  text-align: center;
  padding: 40rpx 30rpx 10rpx;
  font-size: 26rpx;
  color: rgba(255,255,255,0.9);
  letter-spacing: 2rpx;
}

.mode-kicker.drunk {
  color: #FFD700;
  font-weight: bold;
}

.type-card {
  margin: 20rpx 30rpx;
  padding: 40rpx 30rpx;
  background: #fff;
  border-radius: 24rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(46,204,113,0.15);
}

.type-name {
  font-size: 72rpx;
  font-weight: 900;
  color: #2ECC71;
  letter-spacing: 4rpx;
}

.type-cn {
  font-size: 36rpx;
  color: #333;
  margin-top: 10rpx;
  font-weight: 600;
}

.match-badge {
  display: inline-block;
  margin-top: 20rpx;
  padding: 8rpx 24rpx;
  background: linear-gradient(135deg, #2ECC71, #27AE60);
  color: #fff;
  font-size: 24rpx;
  border-radius: 30rpx;
}

.type-intro {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #666;
  font-style: italic;
}

.poster-box {
  margin: 20rpx 30rpx;
  padding: 60rpx 30rpx;
  border-radius: 24rpx;
  text-align: center;
  color: #fff;
  min-height: 300rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.poster-code {
  font-size: 88rpx;
  font-weight: 900;
  letter-spacing: 6rpx;
  text-shadow: 0 4rpx 8rpx rgba(0,0,0,0.2);
}

.poster-cn {
  font-size: 36rpx;
  margin-top: 16rpx;
  font-weight: 600;
}

.poster-intro {
  font-size: 26rpx;
  margin-top: 20rpx;
  opacity: 0.9;
}

.desc-card {
  margin: 20rpx 30rpx;
  padding: 30rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.desc-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 20rpx;
}

.desc-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
}

.dim-section {
  margin: 20rpx 30rpx;
}

.dim-section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 20rpx;
}

.dim-list {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.dim-item {
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.dim-item:last-child {
  border-bottom: none;
}

.dim-item-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.dim-item-name {
  font-size: 26rpx;
  color: #333;
  font-weight: 600;
}

.dim-item-level {
  font-size: 24rpx;
  font-weight: 700;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
}

.level-L {
  background: #E8F5E9;
  color: #4CAF50;
}

.level-M {
  background: #FFF3E0;
  color: #FF9800;
}

.level-H {
  background: #FCE4EC;
  color: #E91E63;
}

.dim-item-bar-bg {
  height: 8rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
  margin-bottom: 10rpx;
}

.dim-item-bar {
  height: 8rpx;
  background: linear-gradient(90deg, #2ECC71, #27AE60);
  border-radius: 4rpx;
  transition: width 0.5s ease;
}

.dim-item-explain {
  font-size: 24rpx;
  color: #888;
  line-height: 1.5;
}

.fun-note {
  margin: 30rpx 30rpx 20rpx;
  padding: 24rpx;
  background: #FFF9C4;
  border-radius: 16rpx;
  font-size: 24rpx;
  color: #795548;
  line-height: 1.6;
}

.actions {
  margin: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.actions button {
  border-radius: 16rpx;
  font-size: 30rpx;
  padding: 24rpx;
  border: none;
}

.btn-retake {
  background: linear-gradient(135deg, #2ECC71, #27AE60) !important;
  color: #fff !important;
}

.btn-home {
  background: #fff !important;
  color: #2ECC71 !important;
  border: 2rpx solid #2ECC71 !important;
}

.btn-share {
  background: linear-gradient(135deg, #FF6B9D, #FF8E53) !important;
  color: #fff !important;
}

.footer {
  text-align: center;
  padding: 20rpx;
  font-size: 22rpx;
  color: #bbb;
}

.loading-box {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 60vh;
}

.loading-text {
  font-size: 30rpx;
  color: #2ECC71;
}
