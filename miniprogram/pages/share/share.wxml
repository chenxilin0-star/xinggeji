<view class="container">
  <!-- 海报 Canvas -->
  <view class="poster-wrap">
    <canvas type="2d" canvas-id="posterCanvas" class="poster-canvas" id="posterCanvas"></canvas>
  </view>

  <!-- 结果预览 -->
  <view class="preview-card" wx:if="{{resultData.result}}">
    <view class="preview-emoji">{{resultData.result.emoji || '🔮'}}</view>
    <view class="preview-title">{{resultData.result.type_name || resultData.result.resultCode || '测试结果'}}</view>
    <view class="preview-desc">{{resultData.result.description || ''}}</view>
    <view class="preview-test">{{testTitles[test_id] || '心理测试'}}</view>
  </view>

  <!-- 操作按钮 -->
  <view class="actions">
    <button class="btn-save" bindtap="savePoster">{{posterSaved ? '✅ 已保存' : '📥 保存海报到相册'}}</button>
    <button class="btn-share" open-type="share">🔗 分享给朋友</button>
    <button class="btn-back" bindtap="backToResult">返回结果</button>
  </view>
</view>
