page {
  background: linear-gradient(135deg, #6C5CE7 0%, #a29bfe 100%);
}

.container {
  padding: 30rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 海报画布（隐藏，只用于绘制） */
.poster-wrap {
  width: 0;
  height: 0;
  overflow: hidden;
}

.poster-canvas {
  width: 375px;
  height: 560px;
}

/* 结果预览卡片 */
.preview-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
  margin-bottom: 40rpx;
  width: 100%;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.1);
  text-align: center;
}

.preview-emoji {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.preview-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.preview-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.7;
  margin-bottom: 20rpx;
}

.preview-test {
  font-size: 22rpx;
  color: #999;
  padding: 6rpx 20rpx;
  background: #f5f5f5;
  border-radius: 20rpx;
  display: inline-block;
}

/* 按钮 */
.actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.btn-save {
  background: #fff;
  color: #6C5CE7;
  border: none;
  box-shadow: 0 6rpx 20rpx rgba(108,92,231,0.2);
}

.btn-share {
  background: rgba(255,255,255,0.2);
  color: #fff;
  border: 2rpx solid rgba(255,255,255,0.3);
}

.btn-back {
  background: transparent;
  color: rgba(255,255,255,0.6);
  border: none;
  font-size: 26rpx;
}

.btn-save, .btn-share, .btn-back {
  padding: 26rpx 0;
  border-radius: 50rpx;
  font-size: 28rpx;
  text-align: center;
  font-weight: 500;
}

.btn-save::after, .btn-share::after, .btn-back::after { border: none; }
