.container {
  padding: 30rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.poster-card {
  width: 560rpx;
  background: linear-gradient(135deg, #6C5CE7 0%, #a29bfe 100%);
  border-radius: 32rpx;
  padding: 8rpx;
  box-shadow: 0 12rpx 40rpx rgba(108, 92, 231, 0.35);
}

.poster-content {
  background: #fff;
  border-radius: 28rpx;
  padding: 48rpx 40rpx;
  text-align: center;
}

.poster-header {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.poster-logo {
  font-size: 48rpx;
  margin-right: 12rpx;
}

.poster-brand {
  font-size: 36rpx;
  font-weight: bold;
  color: #6C5CE7;
  letter-spacing: 2rpx;
}

.poster-result {
  margin-bottom: 48rpx;
}

.poster-emoji {
  font-size: 100rpx;
  display: block;
  margin-bottom: 20rpx;
}

.poster-type {
  font-size: 44rpx;
  font-weight: bold;
  color: #6C5CE7;
}

.poster-qrcode {
  background: #f8f7ff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.qrcode-canvas {
  width: 240rpx;
  height: 240rpx;
  margin: 0 auto 16rpx;
}

.qrcode-tip {
  font-size: 24rpx;
  color: #999;
}

.poster-footer {
  border-top: 2rpx dashed #e8e6f5;
  padding-top: 24rpx;
}

.poster-slogan {
  font-size: 26rpx;
  color: #999;
}

.actions {
  width: 100%;
  padding: 40rpx 30rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn-save, .btn-share {
  width: 100%;
  padding: 28rpx 0;
  border-radius: 50rpx;
  font-size: 30rpx;
  text-align: center;
  font-weight: 500;
}

.btn-save {
  background: linear-gradient(135deg, #6C5CE7 0%, #a29bfe 100%);
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(108, 92, 231, 0.4);
  border: none;
}

.btn-share {
  background: #fff;
  color: #6C5CE7;
  border: 2rpx solid #6C5CE7;
}

.btn-save::after, .btn-share::after {
  border: none;
}
