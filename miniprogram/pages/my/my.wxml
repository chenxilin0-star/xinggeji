<view class="container">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="avatar">
      <text class="avatar-emoji">🔮</text>
    </view>
    <view class="user-name">型格记用户</view>
    <view class="user-id">ID: {{openid || '未登录'}}</view>
  </view>

  <!-- 剩余次数 -->
  <view class="times-card">
    <view class="times-item">
      <view class="times-value">{{free_times}}</view>
      <view class="times-label">今日剩余</view>
    </view>
    <view class="times-divider"></view>
    <view class="times-item">
      <view class="times-value">{{daily_max}}</view>
      <view class="times-label">今日上限</view>
    </view>
  </view>

  <!-- 获取更多次数 -->
  <view class="bonus-tip">
    <text>📤 分享给好友，每次+1次测试机会</text>
  </view>

  <!-- 功能列表 -->
  <view class="menu-list">
    <view class="menu-item" bindtap="showAbout">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-text">关于我们</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="showHelp">
      <text class="menu-icon">❓</text>
      <text class="menu-text">使用说明</text>
      <text class="menu-arrow">›</text>
    </view>
    <button class="menu-item" open-type="share">
      <text class="menu-icon">📤</text>
      <text class="menu-text">分享给好友（+1次）</text>
      <text class="menu-arrow">›</text>
    </button>
  </view>

  <!-- 底部信息 -->
  <view class="footer">
    <text>型格记 v2.0</text>
    <text>探索内心，发现真实的自己</text>
  </view>

  <!-- 分享后领取奖励浮层 -->
  <view class="reward-overlay" wx:if="{{showRewardSheet}}" bindtap="claimReward">
    <view class="reward-card">
      <text class="reward-emoji">🎁</text>
      <text class="reward-text">已分享？点击领取+1次奖励</text>
    </view>
  </view>
</view>
