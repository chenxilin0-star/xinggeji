.container {
  padding: 30rpx;
  min-height: 100vh;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.free-times {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  background: rgba(255, 255, 255, 0.2);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.records-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.record-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(108, 92, 231, 0.15);
}

.record-emoji {
  font-size: 50rpx;
  margin-right: 25rpx;
}

.record-info {
  flex: 1;
}

.record-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.record-result {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #6C5CE7;
  margin-bottom: 8rpx;
}

.record-result text:first-child {
  margin-right: 10rpx;
}

.record-time {
  font-size: 22rpx;
  color: #999;
}

.record-arrow {
  font-size: 40rpx;
  color: #ccc;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-emoji {
  font-size: 80rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #fff;
  margin-bottom: 15rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
}

.loading-state {
  text-align: center;
  padding: 50rpx;
  color: rgba(255, 255, 255, 0.8);
}
