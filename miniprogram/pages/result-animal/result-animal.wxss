.container {
  min-height: 100vh;
  background: linear-gradient(160deg, #FF9A56 0%, #FFD166 50%, #FFF5E6 100%);
  padding: 0 30rpx 60rpx;
  padding-bottom: 80rpx;
  position: relative;
}

.loading { text-align: center; padding: 200rpx 0; color: #fff; }

/* 顶部 */
.header-card {
  text-align: center;
  padding: 70rpx 30rpx 40rpx;
}

.animal-emoji-wrap {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.3);
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.08);
}

.animal-emoji {
  font-size: 100rpx;
}

.animal-name {
  font-size: 48rpx;
  font-weight: 900;
  color: #fff;
  margin-top: 20rpx;
  text-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.animal-tagline {
  font-size: 28rpx;
  color: rgba(255,255,255,0.85);
  margin-top: 10rpx;
  font-style: italic;
}

/* 卡片 */
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(242,153,74,0.1);
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  padding-bottom: 14rpx;
  border-bottom: 2rpx solid #f5f0eb;
}

/* 环形图 */
.donut-wrapper {
  width: 100%;
  height: 300rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.donut-canvas {
  width: 300rpx;
  height: 300rpx;
}

.percent-list {
  display: flex;
  justify-content: space-around;
  margin-top: 20rpx;
}

.percent-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.pi-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.pi-emoji { font-size: 28rpx; }
.pi-name { font-size: 22rpx; color: #999; }
.pi-val { font-size: 26rpx; font-weight: bold; color: #333; }

/* 关键词 */
.keyword-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  justify-content: center;
}

.kw-tag {
  padding: 10rpx 26rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  font-weight: 600;
  border: 2rpx solid;
}

/* 概述 */
.desc-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.9;
  text-align: justify;
}

/* 特征列表 */
.trait-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.trait-item {
  padding: 18rpx 22rpx;
  background: #fafafa;
  border-radius: 14rpx;
  border-left: 6rpx solid #F5A623;
}

.trait-item.blind-item {
  border-left-color: #E74C3C;
}

.trait-name {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 6rpx;
}

.trait-name.blind {
  color: #E74C3C;
}

.trait-desc {
  font-size: 24rpx;
  color: #888;
  line-height: 1.6;
}

/* 建议 */
.advice-section {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.advice-item {
  padding: 20rpx 24rpx;
  background: #fafafa;
  border-radius: 14rpx;
}

.advice-label {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.advice-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.7;
}

/* 按钮 */
.actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 24rpx;
}

.btn-share {
  background: linear-gradient(135deg, #F2994A, #F2C94C);
  color: #fff;
  border: none;
  box-shadow: 0 6rpx 24rpx rgba(242,153,74,0.3);
}

.btn-retake {
  background: #fff;
  color: #F2994A;
  border: 2rpx solid #F2994A;
}

.btn-home {
  background: transparent;
  color: rgba(255,255,255,0.7);
  border: none;
}

.btn-share, .btn-retake, .btn-home {
  padding: 26rpx 0;
  border-radius: 50rpx;
  font-size: 28rpx;
  text-align: center;
  font-weight: 600;
}

.btn-share::after, .btn-retake::after, .btn-home::after { border: none; }
